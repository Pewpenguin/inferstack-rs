# Basic configuration
MODEL_PATH=./model.onnx
PORT=3000
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60
MAX_INPUT_SIZE=1024
MIN_INPUT_SIZE=1
MAX_BATCH_SIZE=32

# Model versioning configuration
# Format: MODEL_VERSIONS="v1:path/to/model1.onnx:80:Description 1,v2:path/to/model2.onnx:20:Description 2"
# Where each version is defined as: version:path:traffic_allocation:description
MODEL_VERSIONS=v1:model.onnx:100:Default model
# DEFAULT_MODEL_VERSION=v1